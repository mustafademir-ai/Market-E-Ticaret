<%@ Master="" Language="C#" AutoEventWireup="true" CodeBehind="SiteMaster.master.cs" Inherits="MarketETicaret.SiteMaster" %>

	<!DOCTYPE html>
	<html lang="tr">
		<head runat="server">
			<meta charset="utf-8" />
			<title>MarketETicaret</title>
			<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
			<link href="Styles/site.css" rel="stylesheet" />
			<asp:ContentPlaceHolder ID="head" runat="server"></asp:ContentPlaceHolder>
		</head>
		<body>
			<form runat="server">
				<!-- Navbar -->
				<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
					<div class="container">
						<a class="navbar-brand" href="Default.aspx">MarketETicaret</a>
						<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
							<span class="navbar-toggler-icon"></span>
						</button>
						<div class="collapse navbar-collapse" id="navbarNav">
							<ul class="navbar-nav me-auto mb-2 mb-lg-0">
								<li class="nav-item">
									<a class="nav-link" href="Default.aspx">Ana Sayfa</a>
								</li>
								<li class="nav-item">
									<a class="nav-link" href="Kategoriler.aspx">Kategoriler</a>
								</li>
								<li class="nav-item">
									<a class="nav-link" href="Siparisler.aspx">Siparişlerim</a>
								</li>
								<li class="nav-item">
									<a class="nav-link" href="Iletisim.aspx">İletişim</a>
								</li>
							</ul>
							<ul class="navbar-nav">
								<li class="nav-item">
									<asp:LoginView ID="lvUserMenu" runat="server">
										<AnonymousTemplate>
											<a class="nav-link" href="Login.aspx">Giriş / Kayıt</a>
										</AnonymousTemplate>
										<LoggedInTemplate>
											<a class="nav-link" href="Profil.aspx">
												<%: Context.User.Identity.Name %>
											</a>
											<asp:LoginStatus ID="LoginStatus1" runat="server" LogoutText="Çıkış" LogoutAction="Redirect" LogoutPageUrl="Default.aspx" />
											<a class="nav-link" href="Sepet.aspx">
												Sepet <asp:Label ID="lblSepetAdet" runat="server" CssClass="badge bg-danger">0</asp:Label>
											</a>
										</LoggedInTemplate>
									</asp:LoginView>
								</li>
							</ul>
						</div>
					</div>
				</nav>

				<!-- İçerik -->
				<div class="container mt-4">
					<asp:ContentPlaceHolder ID="MainContent" runat="server">
					</asp:ContentPlaceHolder>
				</div>

				<!-- Footer -->
				<footer class="bg-dark text-white mt-5 pt-4 pb-4">
					<div class="container">
						<div class="row">
							<!-- Hakkımızda -->
							<div class="col-md-4">
								<h5>Hakkımızda</h5>
								<p>MarketETicaret, güvenli ve hızlı alışveriş deneyimi sunan profesyonel bir e-ticaret sitesidir.</p>
							</div>

							<!-- Menü -->
							<div class="col-md-4">
								<h5>Hızlı Menü</h5>
								<ul class="list-unstyled">
									<li>
										<a href="Default.aspx" class="text-white">Ana Sayfa</a>
									</li>
									<li>
										<a href="Kategoriler.aspx" class="text-white">Kategoriler</a>
									</li>
									<li>
										<a href="Siparisler.aspx" class="text-white">Siparişlerim</a>
									</li>
									<li>
										<a href="Iletisim.aspx" class="text-white">İletişim</a>
									</li>
								</ul>
							</div>

							<!-- İletişim -->
							<div class="col-md-4">
								<h5>İletişim</h5>
								<p>Adres: Örnek Mah. 123. Sok. İstanbul</p>
								<p>Telefon: +90 555 123 45 67</p>
								<p>Email: info@marketeticaret.com</p>
								<p>Çalışma Saatleri: 09:00 - 18:00</p>
							</div>
						</div>
						<hr class="bg-white" />
						<div class="text-center">
							&copy; 2025 MarketETicaret | Tüm Hakları Saklıdır
						</div>
					</div>
				</footer>
			</form>

			<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
		</body>
	</html>
